# alexmchong.ca — production webroot .htaccess
# Phase 3: legacy redirects + front controller fallback.
# Static marketing pages serve directly; anything that isn't a real file
# or directory drops through to index.php for routing.

# Custom 404 page (rendered by Apache when no rule below matches and no
# file exists at the requested path). Ships from site/_pages/404.php —
# PHP so the favicon and similar can env-gate.
ErrorDocument 404 /404.php

# === Security headers (Phase 24 hardening) ==================================
# Cheap, zero-breakage defense-in-depth. CSP is deliberately minimal: it sets
# only object-src/base-uri/frame-ancestors — NOT script-src — because the
# Settings page lets the author paste an external analytics <script>, which a
# strict script-src would block. A full nonce-based CSP is deferred.
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Strict-Transport-Security "max-age=31536000"
  Header always set Content-Security-Policy "object-src 'none'; base-uri 'self'; frame-ancestors 'self'"
</IfModule>

RewriteEngine On

# === Legacy redirects (Phase 13) ============================================
# The external 302 block and the legacy-renames block both moved to the
# `redirects` table in Phase 13 — site/db/migrations/0011 seeds them, the
# CMS view at /cms/redirects manages them, and the front controller's
# not-found handler in site/index.php resolves them. See:
#   docs/LEGACY-ROUTES.md §2  (the canonical inventory)
#   site/lib/redirects.php    (resolver + emit)
# DO NOT re-add Apache-level RewriteRule lines for those paths here — the
# DB layer is the single source of truth post-Phase-13.

# === /admin → /cms (301, permanent — AUTH-SECURITY.md §9) ===================
RewriteRule ^admin/?$       /cms/    [R=301,L]
RewriteRule ^admin/(.*)$    /cms/$1  [R=301,L]

# === .html → canonical bare-path (visible 302) ==============================
# Anyone hitting /foo.html gets bounced to the canonical /foo/ form so SEO and
# bookmarks converge on one URL per page.
RewriteRule ^about\.html$ /about/ [R=302,L]
RewriteRule ^coaching\.html$ /coaching/ [R=302,L]
RewriteRule ^work-with-me\.html$ /work-with-me/ [R=302,L]
RewriteRule ^resume\.html$ /resume/ [R=302,L]
RewriteRule ^newsletter\.html$ /newsletter/ [R=302,L]
RewriteRule ^newsletter-confirmed\.html$ /newsletter-confirmed/ [R=302,L]

# === Canonical bare-path → silent internal rewrite to .php =================
# URL bar stays at /foo/. [END] terminates the rewrite engine so the engine
# doesn't restart and re-trigger the .html→bare 302 rules above (would loop).
# Targets are .php (each is a thin assembler that includes the shared head,
# header.html, the matching body from _bodies/, and footer.html).
RewriteRule ^$ /landing.php [END]
RewriteRule ^about/?$ /about.php [END]
RewriteRule ^coaching/?$ /coaching.php [END]
RewriteRule ^work-with-me/?$ /work-with-me.php [END]
RewriteRule ^resume/?$ /resume.php [END]
RewriteRule ^newsletter/?$ /newsletter.php [END]
RewriteRule ^newsletter-confirmed/?$ /newsletter-confirmed.php [END]

# === Front controller fallback (Phase 3) ====================================
# For any URL that isn't a real file or directory, hand off to index.php.
# Static marketing pages (about.html, _layout/*, _ds/*) still serve directly
# because RewriteCond !-f / !-d skips them. Legacy [END]-terminated rules
# above also short-circuit this fallback — those rewrites stop the engine.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]

# === Direct-file serving ====================================================
# Anything that didn't match a rule above and IS a real file/dir on disk
# falls through to Apache's default behavior: serve the file directly.
